{
  "name": "codeshot-dev",
  "type": "module",
  "workspaces": [
    ".wasp/out/*",
    ".wasp/out/sdk/wasp"
  ],
  "scripts": {
    "dev": "wasp start",
    "build": "wasp build && tsc -b && REACT_APP_API_URL=https://code-screenshot.static.miho.dev npx vite build",
    "preview": "vite preview",
    "deploy": "npm run build && npx --yes @infomiho/buzz-cli@0.7.0 deploy ./.wasp/out/web-app/build --subdomain code-screenshot --server https://static.miho.dev"
  },
  "dependencies": {
    "@codemirror/commands": "^6.10.4",
    "@codemirror/lang-css": "^6.3.1",
    "@codemirror/lang-html": "^6.4.11",
    "@codemirror/lang-javascript": "^6.2.5",
    "@codemirror/lang-json": "^6.0.2",
    "@codemirror/lang-markdown": "^6.5.0",
    "@codemirror/lang-python": "^6.2.1",
    "@codemirror/language": "^6.12.4",
    "@codemirror/state": "^6.7.1",
    "@codemirror/view": "^6.43.6",
    "@lezer/highlight": "^1.2.3",
    "codemirror": "^6.0.2",
    "modern-screenshot": "^4.7.0",
    "perfect-freehand": "^1.2.3",
    "react": "^19.2.1",
    "react-dom": "^19.2.1",
    "react-router": "^7.12.0"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@wasp.sh/spec": "file:.wasp/spec/",
    "prisma": "5.19.1",
    "typescript": "5.9.3",
    "vite": "^7.0.6",
    "vitest": "^4.0.16"
  }
}
